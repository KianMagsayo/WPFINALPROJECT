<Window x:Class="MAGSAYOWPFINAL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MAGSAYOWPFINAL"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="940">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>


        <Label Grid.Row="1" Grid.ColumnSpan="2"
               FontStyle="Normal" FontWeight="Bold"
               HorizontalContentAlignment="Center"
               FontSize="26"
               Background="DarkKhaki"
               Content="CUSTOMER INFORMATION MENU" FontFamily="Bahnschrift" Margin="3,0,0,0"/>
        <Label
               FontStyle="Normal"
               FontWeight="Bold"
               HorizontalContentAlignment="Center"
               FontSize="26"
               Background="DarkKhaki"
               Content="CUSTOMER DETAIL" Grid.Column="2" Margin="23,0,0,0" Grid.Row="1"/>
        <Separator Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" />

        <StackPanel Grid.Row="3" Grid.Column="1"
                    Orientation="Vertical"
                    x:Name="panelStudentTable" Grid.ColumnSpan="2" Margin="0,0,323,3" Grid.RowSpan="2">
            <DataGrid x:Name="dataGrid" Height="350"
                      AutoGenerateColumns="False"
                      SelectionChanged="dataGrid_SelectionChanged"
                      Background="Transparent"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Customer Name"
                            Binding="{Binding CustomerName}" />
                    <DataGridTextColumn Header="Customer Address"
                            Binding="{Binding Address}" />
                    <DataGridTextColumn Header="Payment"
                            Binding="{Binding Payment}" />
                    <DataGridTextColumn Header="Order"
                                        Binding="{Binding Order}"/>
                    <DataGridTextColumn Header="Quantity"
                            Binding="{Binding Quantity}" />
                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price}"/>
                    <DataGridTextColumn Header="Discount"
                                        Binding="{Binding Discount}"/>
                    <DataGridTextColumn Header="Total Amount"
                                        Binding="{Binding TotalAmount}"/>
                </DataGrid.Columns>
            </DataGrid>
            <Button x:Name="btnDeleteData" Content="REMOVE SELECTED CUSTOMER ORDERS"
                    Height="50" FontSize="20"
                    FontWeight="Bold"
                    IsEnabled="False"
                    Cursor="Hand"
                    Click="btnDeleteData_Click_1"
                    Background="Aqua" RenderTransformOrigin="0.501,1.899"
                    />
            <Button x:Name="btnDeliver" Content="DELIVER ORDER"
                    Height="50"
                    FontSize="20"
                    FontWeight="Bold"
                    Margin="0,5"
                    IsEnabled="False"
                    Cursor="Hand"
                    Click="btnOrderDeliver_Click"
                    Background="Aqua"/>
            <Button x:Name="btnClearData"
                    Content="CLEAR ALL DATA"
                    Height="39"
                    FontSize="20"
                    FontWeight="Bold"
                    Margin="0,5"
                    IsEnabled="True"
                    Cursor="Hand"
                    Click="btnClearData_Click"
                    Background="Aqua" Width="615"/>
            <Button x:Name="btnPending"
                    FontSize="20"
                    FontWeight="Bold"
                    Background="Aqua"
                    IsEnabled="True"
                    Content="SET TO DELIVER"
                    Click="btnPending_Click" Width="641" Height="45"/>
            <Button x:Name="btnClose" Content="CLOSE MENU"
                    Height="40"
                    FontSize="20"
                    FontWeight="UltraBold"
                    IsEnabled="True"
                    Cursor="Hand"
                    Click="btnCloseMenu_Click"
                    Background="OrangeRed" Width="614"/>
        </StackPanel>

        <Grid Grid.Row="2" Grid.Column="2" Margin="10,2,-10,0" Grid.RowSpan="3" RenderTransformOrigin="0.511,0.49" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="94.333"/>
                <ColumnDefinition Width="62"/>
                <ColumnDefinition Width="32.334"/>
                <ColumnDefinition Width="114.666"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="169"/>
                <RowDefinition Height="71.71"/>
                <RowDefinition Height="67"/>
            </Grid.RowDefinitions>
            <Label
                   Grid.Column="1"
                   Content="Customer Name"
                   FontSize="13"
                   Padding="1"
                   Background="Aqua"
                   FontWeight="DemiBold" Grid.ColumnSpan="4" Margin="2,2,10,2" />
            <TextBox
                     x:Name="txtCustomerName"
                     Grid.Column="1" 
                     Cursor="Pen"
                     HorizontalContentAlignment="Left"
                     FontSize="14"
                     Background="BlanchedAlmond"
                     BorderThickness="0,0,0,1"
                     Padding="2" Grid.ColumnSpan="4" Margin="2,20,10,10" Grid.RowSpan="3" />
            <Label Grid.Row="2"
                   Grid.Column="1"
                   Background="Aqua"
                   Content="Customer Address"
                   FontSize="13"
                   Padding="1"                  
                   FontWeight="DemiBold" Grid.ColumnSpan="4" Margin="2,10,10,20" Grid.RowSpan="2" />
            <TextBox Grid.Row="3"
                     x:Name="txtAddress"
                     Grid.Column="1" 
                     Cursor="Pen"
                     HorizontalContentAlignment="Left"
                     FontSize="14"
                     BorderThickness="0,0,0,1"
                     Background="BlanchedAlmond"
                     Padding="2" Grid.ColumnSpan="4" Margin="2,10,10,0" Grid.RowSpan="2" />
            <Label Grid.Row="5"
                   Grid.Column="1"
                   Background="Aqua"
                   Content="Order"
                   FontSize="13"
                   Padding="1"
                   FontWeight="DemiBold" Margin="2,0,0,0" RenderTransformOrigin="0.492,0.802" Grid.ColumnSpan="4" HorizontalAlignment="Left" Width="292">
                <Label.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="-0.16"/>
                        <RotateTransform/>
                        <TranslateTransform Y="-0.161"/>
                    </TransformGroup>
                </Label.RenderTransform>
            </Label>
            <ComboBox x:Name="comboboxOrder"
                      Grid.Row="6"         
                      Cursor="Hand"
                      Background="BlanchedAlmond"
                      BorderThickness="0" Grid.Column="1" Grid.ColumnSpan="4" Margin="2,0,10,0">
                <ComboBoxItem Content="BURGER"/>
                <ComboBoxItem Content="CHICKEN JOY"/>
                <ComboBoxItem Content="SULIT MEAL"/>
                <ComboBoxItem Content="YUMBURGER"/>
                <ComboBoxItem Content="JOLLY SPAGHETTI FAMILY PLAN"/>
                <ComboBoxItem Content="BURGER STEAK"/>
                <ComboBoxItem Content="CHICKEN FILLET"/>
                <ComboBoxItem Content="FRIES AND SIDES"/>
                <ComboBoxItem Content="CHICKEN NUGGETS"/>
                <ComboBoxItem Content="SANDWICHES AND SAVORY PIES"/>
                <ComboBoxItem Content="JOLLY SPAGHETTI AND PALABOK"/>
            </ComboBox>

            <Label Grid.Row="7"
                   Background="Aqua"
                   Content="Payment"
                   FontSize="13"
                   Padding="1"
                   FontWeight="DemiBold" Margin="0,0,10,10" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Width="291" />
            <ComboBox x:Name="comboBoxPayment"
                      Grid.Row="8"
                      Cursor="Hand"
                      Background="BlanchedAlmond"
                      BorderThickness="0" Margin="2,11,10,9" Grid.RowSpan="2" RenderTransformOrigin="0.5,0.5" Grid.ColumnSpan="4" Grid.Column="1">
                <ComboBox.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="0.094"/>
                        <RotateTransform/>
                        <TranslateTransform Y="-0.248"/>
                    </TransformGroup>
                </ComboBox.RenderTransform>
                <ComboBoxItem Content="Gcash"/>
                <ComboBoxItem Content="Paypal"/>
                <ComboBoxItem Content="Paymaya"/>
                <ComboBoxItem Content="BDO"/>
                <ComboBoxItem Content="Cash"/>
                <ComboBoxItem Content="Cash on Delivery"/>
            </ComboBox>
            <Label Grid.Row="9"
                     Grid.Column="1"
                     Background="Aqua"
                     Content="Price"
                     FontSize="13"
                     Padding="1"
                     FontWeight="DemiBold" Margin="2,20,0,15" Grid.ColumnSpan="4" Grid.RowSpan="4" HorizontalAlignment="Left" Width="291" />
            <TextBox Grid.Row="11"
                     x:Name="txtPrice"
                     Grid.Column="1" 
                     Cursor="Hand"
                     HorizontalContentAlignment="Center"
                     FontSize="14"
                     Background="BlanchedAlmond"
                     BorderThickness="0,0,0,1"
                     Padding="2" Margin="2,4,36,15" Grid.ColumnSpan="2" Grid.RowSpan="2"/>
            <Label Grid.Row="12"
                   Background="Aqua"
                   Content="Discount"
                   FontSize="13"
                   Padding="1"
                   FontWeight="DemiBold" Margin="2,15,10,123" Grid.ColumnSpan="4" Grid.RowSpan="2" Grid.Column="1" />
            <TextBox Grid.Row="13"
                   x:Name="txtDiscount"
                   Grid.Column="1" 
                   Cursor="Hand"
                   HorizontalContentAlignment="Center"
                   FontSize="14"
                     Background="BlanchedAlmond"
                   BorderThickness="0,0,0,1"
                   Padding="2" Margin="2,7,38,122" Grid.ColumnSpan="2"/>
            <Label Grid.Row="12"
                   Background="Transparent"
                   Content="Quantity"
                   FontSize="13"
                   Padding="1"
                   FontWeight="DemiBold" Margin="0,15,6,154" HorizontalAlignment="Right" Width="182" Grid.Column="2" Grid.ColumnSpan="4" Grid.RowSpan="2" />
            <TextBox x:Name="txtQuantity"
                    Grid.Row="13"
                    Grid.Column="2"
                    Grid.ColumnSpan="3"
                    Margin="31,7,61,122"
                    FontSize="14"
                    HorizontalContentAlignment="Center"
                    BorderThickness="0,0,0,1"
                    Padding="2"
                     Background="BlanchedAlmond"
                    Cursor="Hand" RenderTransformOrigin="1.541,-0.029"/>
            <StackPanel Grid.Row="13"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        Cursor="Hand"
                        Orientation="Horizontal" Margin="0,68,0,41" Width="318" RenderTransformOrigin="0.5,0.5" Grid.ColumnSpan="6" Grid.RowSpan="2"/>
            <Button x:Name="btnSave" Grid.Row="13"
                    Content="SAVE" FontSize="20"
                    Click="btnSave_Click"
                    FontWeight="Bold"
                    Margin="5,68,10,0"                  
                    Background="Aqua" RenderTransformOrigin="0.508,1.078" Grid.ColumnSpan="4" Grid.Column="1"/>
            <Button x:Name ="btnUnsave"
                    Grid.Row="14"
                    Content="CLEAR"
                    Click="Unsaved_Click"
                    Grid.ColumnSpan="4"
                    FontWeight="bold"
                    FontSize="20"
                    Margin="5,10,10,34" Grid.RowSpan="2" Grid.Column="1"
                    Background="Aqua"
                    />
        </Grid>
    </Grid>
</Window>
